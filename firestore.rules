rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Schema Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'role']) &&
             data.id is string && data.id == request.auth.uid &&
             data.name is string && data.name.size() <= 150 &&
             data.email is string && data.email.size() <= 150 &&
             data.role in ['user', 'admin'] &&
             (!('learningProgress' in data) || data.learningProgress is int) &&
             (!('savedBlogs' in data) || data.savedBlogs is list) &&
             (!('savedTools' in data) || data.savedTools is list);
    }

    function isValidMockAttempt(data) {
      return data.keys().hasAll(['id', 'userId', 'examType', 'section', 'score', 'totalQuestions', 'createdAt']) &&
             data.id is string &&
             data.userId == request.auth.uid &&
             data.examType in ['ssc-cgl', 'gate', 'fresher-qa'] &&
             data.section in ['quantitative-aptitude', 'general-english', 'logical-reasoning', 'general-awareness', 'english-grammar', 'full-length-mock'] &&
             data.score is int &&
             data.totalQuestions is int &&
             (!('accuracy' in data) || data.accuracy is int) &&
             (!('timeSpent' in data) || data.timeSpent is int);
    }

    // Match Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().role == existing().role
      );
      allow delete: if false;

      match /mockAttempts/{attemptId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMockAttempt(incoming()) && incoming().createdAt == request.time;
        allow update, delete: if false; // Mock data attempts are immutable audit records
      }
    }
  }
}
